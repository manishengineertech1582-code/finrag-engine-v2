# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# ── Storage ───────────────────────────────────────────────────────────────────
VECTORSTORE_PATH=vector_store
UPLOAD_DIR=data/raw
MAX_FILE_SIZE_MB=50

# ── Chunking (format-aware defaults in src/chunking.py — override here) ───────
# CHUNK_SIZE=800
# CHUNK_OVERLAP=150

# ── Retrieval ─────────────────────────────────────────────────────────────────
TOP_K=8
USE_MULTI_QUERY=true
USE_HYBRID_SEARCH=true
HYBRID_BM25_WEIGHT=0.3
RERANK_THRESHOLD=0.75

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# ── CORS (production only — comma-separated origins) ──────────────────────────
# CORS_ORIGINS=https://myapp.com,https://api.myapp.com

# ── LangSmith Observability ───────────────────────────────────────────────────
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls__your-key-here
# LANGCHAIN_PROJECT=finrag-engine

# ── Supabase Auth ─────────────────────────────────────────────────────────────
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=eyJ...
# SUPABASE_JWT_SECRET=your-jwt-secret
